# Maintainer: sam <sampyeatt4@proton.me>
pkgname=projecttracker-bin
pkgver=0.1.0
pkgrel=1
pkgdesc="Project tracker application"
arch=('x86_64')
url="https://github.com/sampyeatt/ProjectTracker"
license=('MIT')
depends=('webkit2gtk-4.1' 'libayatana-appindicator' 'librsvg')
provides=('projecttracker')
conflicts=('projecttracker')
source_x86_64=("${url}/releases/download/app-v${pkgver}/projecttracker_${pkgver}_amd64.AppImage")
sha256sums_x86_64=('SKIP')
noextract=("projecttracker_${pkgver}_amd64.AppImage")

prepare() {
    chmod +x "projecttracker_${pkgver}_amd64.AppImage"
    ./"projecttracker_${pkgver}_amd64.AppImage" --appimage-extract
}

package() {
    install -dm755 "${pkgdir}/opt/projecttracker"
    cp -r squashfs-root/* "${pkgdir}/opt/projecttracker/"

    install -dm755 "${pkgdir}/usr/bin"
    ln -s /opt/projecttracker/AppRun "${pkgdir}/usr/bin/projecttracker"

    if [[ -f "squashfs-root/projecttracker.desktop" ]]; then
        install -Dm644 "squashfs-root/projecttracker.desktop" \
            "${pkgdir}/usr/share/applications/projecttracker.desktop"
    fi

    for size in 16 32 48 64 128 256 512; do
        if [[ -f "squashfs-root/usr/share/icons/hicolor/${size}x${size}/apps/projecttracker.png" ]]; then
            install -Dm644 "squashfs-root/usr/share/icons/hicolor/${size}x${size}/apps/projecttracker.png" \
                "${pkgdir}/usr/share/icons/hicolor/${size}x${size}/apps/projecttracker.png"
        fi
    done
}
